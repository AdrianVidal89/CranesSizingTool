# Copy to `.env.nas` (same directory as docker-compose.nas.yml) and
# replace every CHANGE_ME. Never commit the real file — `.env*` besides
# the `*.example` files is already gitignored.
#
# Used with: docker compose --env-file .env.nas -f docker-compose.nas.yml up -d
# (a distinct filename from `.env`/`.env.example`, which are for the
# internet-facing docker-compose.prod.yml, so both can coexist in the
# same checkout without colliding.)

# --- Postgres ---
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=CHANGE_ME

# --- Network ---
# How the browser reaches this app on your LAN, e.g. http://192.168.1.50:8090
# — your NAS's LAN IP or hostname, plus NAS_HTTP_PORT below. Only used
# as a defensive CORS allowlist; the app itself talks same-origin
# through nginx regardless of this value (see docs/NAS_DEPLOYMENT.md).
LAN_ORIGIN=http://CHANGE_ME:8090
# Host port nginx publishes. QNAP's own admin UI often uses 8080, so
# this defaults to 8090 — change it if that's also taken.
NAS_HTTP_PORT=8090

# --- Application secrets ---
# High-entropy secret used to derive the column-level encryption-at-rest
# key. Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_SECRET=CHANGE_ME

# --- Backups (optional — sensible default if omitted) ---
# BACKUP_RETENTION_DAYS=14
