# Copy this file to `.env` (same directory as docker-compose.prod.yml)
# and replace every CHANGE_ME. Never commit the real `.env` — it is
# already listed in .gitignore.
#
# docker compose reads this file automatically to fill in the ${VAR}
# references in docker-compose.prod.yml; those values are then passed
# into each container's environment. See docs/DEPLOYMENT.md for what
# each variable does and how to generate a good value for it.

# --- Postgres ---
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=CHANGE_ME

# --- Domain / TLS ---
# Public DNS name the VPS is reachable at, e.g. cranes.example.com.
DOMAIN=CHANGE_ME
# Used only by scripts/init-letsencrypt.sh for Let's Encrypt account
# registration (expiry notices), not stored anywhere else.
LETSENCRYPT_EMAIL=CHANGE_ME

# --- Application secrets ---
# High-entropy secret used to derive the column-level encryption-at-rest
# key. Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_SECRET=CHANGE_ME

# --- Backups (optional — sensible defaults if omitted) ---
# BACKUP_RETENTION_DAYS=14
# BACKUP_INTERVAL_SECONDS=86400
